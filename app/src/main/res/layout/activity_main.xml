<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waktu Sholat"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnAdzan"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Pengingat Adzan"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnTasbih"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Tasbih Digital"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnAdzan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnKiblat"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Arah Kiblat"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnTasbih"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>